{
    "name": "Magnonics Lab",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "jupyter.notebookEditor.defaultInterpreterPath": "/usr/local/bin/python"
            },
            "extensions": [
                "ms-python.python",        // Сам Питон
                "ms-python.vscode-pylance", // Умные подсказки (чтобы не было красных линий)
                "ms-toolsai.jupyter",       // ТОТ САМЫЙ ЮПИТЕР
                "ms-toolsai.jupyter-renderers", // Чтобы графики рисовались красиво
                "ms-toolsai.jupyter-keymap"    // Горячие клавиши для блокнотов
            ]
        }
    },
    "postCreateCommand": "/usr/local/bin/python -m pip install -r requirements.txt"
}
